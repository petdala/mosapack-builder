{
  "$comment": "MosaPack shared production constants v1.1 \u2014 single source of truth for production physics. Repo home: config/production-constants.json (runtime-imported by web sheet math AND generator loaders). All linear dimensions in INCHES. No logic here; loaders validate.",
  "schema_version": 1.1,
  "updated": "2026-07-07",
  "sheet_profiles": {
    "OL2050": {
      "$comment": "OnlineLabels OL2050-class pre-die-cut stock: 0.5in squares, 221-up on US Letter. Derived from published specs \u2014 RE-VERIFY against vendor template before first production print.",
      "profile_id": "OL2050",
      "verified": false,
      "verification_status": "pending_alignment_test",
      "page": "letter",
      "page_w_in": 8.5,
      "page_h_in": 11.0,
      "cols": 13,
      "rows": 17,
      "pitch_in": 0.625,
      "die_in": 0.5,
      "margin_left_in": 0.25,
      "margin_top_in": 0.25,
      "gap_in": 0.125,
      "stickers_per_sheet": 221
    },
    "OL5425": {
      "$comment": "1in squares, 80-up (10x8). Candidate for future large-cell SKUs. Geometry UNVERIFIED \u2014 placeholder from catalog listing; verify before use.",
      "profile_id": "OL5425",
      "page": "letter",
      "page_w_in": 8.5,
      "page_h_in": 11.0,
      "cols": 8,
      "rows": 10,
      "pitch_in": 1.0,
      "die_in": 1.0,
      "margin_left_in": 0.25,
      "margin_top_in": 0.5,
      "gap_in": 0.0,
      "stickers_per_sheet": 80,
      "verified": false,
      "verification_status": "unverified_future_profile"
    }
  },
  "default_profile": "OL2050",
  "print": {
    "bleed_in": 0.03,
    "bleed_escalation_in": 0.05,
    "bleed_ceiling_in": 0.0625,
    "$comment": "bleed_ceiling = gap_in / 2 for OL2050. Registration pass: offset <= 0.5mm both axes across 3 consecutive sheets, zero visible liner slivers; escalate to bleed_escalation_in for repeatable 0.5-1.2mm offsets; vendor-print beyond that or for skew > 0.7mm corner differential."
  },
  "spares": {
    "rate": 0.05,
    "basis": "per_color_ceil_over_placed_cells",
    "placement": "appended_after_main_sequence_grouped_by_color_desc"
  },
  "sections": {
    "candidate_sizes": [
      16,
      12,
      8,
      6
    ],
    "rule": "first candidate that evenly divides grid; fallback = whole grid",
    "order": "section_major_then_row_major_within_section"
  },
  "black_base": {
    "trigger": "design.black_base == true",
    "sparse_guide_threshold_placed": 700,
    "$comment": "Exclusion keys on palette entry id=='ink_black' post-quantization, never on display name or luminance. Excluded cells remain in cell_map and manifests (on_base=true); only the sticker sequence omits them.",
    "excluded_color_id": "ink_black"
  },
  "board": {
    "bleed_in": 0.125,
    "fill_hex": "#141518",
    "grid_hairline_hex": "#2E3136",
    "grid_major_hex": "#3A3E44",
    "grid_major_every_cells": 6,
    "label_hex": "#4A4E55"
  },
