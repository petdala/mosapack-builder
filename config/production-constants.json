  "fulfillment_modes": {
    "printed_mixed_sheets": {
      "status": "implemented",
      "default": true,
      "description": "Custom per-design mixed sheets ordered by build sequence.",
      "best_for": [
        "premium",
        "high-color",
        "fine-control",
        "made-to-order"
      ]
    },
    "stock_color_sheets": {
      "status": "internal_math_candidate",
      "default": false,
      "description": "Full pre-approved color sheets per palette color; extras included.",
      "best_for": [
        "low-color starter kits",
        "supplier conversations",
        "possible grayscale/simple kits"
      ],
      "max_palette_colors_launch_hint": 4,
      "waste_warning": "Pure stock becomes inefficient when average placed per color is below about 150.",
      "customer_extra_note": "Includes spare stickers in every color for mistakes, repairs, and finishing touches."
    },
    "hybrid_stock_plus_topoff": {
      "status": "future",
      "default": false,
      "description": "Stock sheets for high-count colors plus mixed top-off sheet for rare colors.",
      "stock_min_per_color_default": 150
    }
  },
  "print": {
    "bleed_in": 0.03,
    "bleed_escalation_in": 0.05,
    "bleed_ceiling_in": 0.0625,
    "$comment": "bleed_ceiling = gap_in / 2 for OL2050. Registration pass: offset <= 0.5mm both axes across 3 consecutive sheets, zero visible liner slivers; escalate to bleed_escalation_in for repeatable 0.5-1.2mm offsets; vendor-print beyond that or for skew > 0.7mm corner differential."
  },
  "gamut_profiles": {
    "srgb-print-safe-v1": {
      "$comment": "Config boundary shared with adaptivePalette.ts printableLab(). V1 accepts D65 sRGB colors after constraining L* to 3..97 and reducing chroma by 0.9 per iteration until the color is representable in sRGB. This is a conservative printable approximation, not a vendor ICC profile.",
      "color_space": "srgb_d65",
      "l_star_min": 3.0,
      "l_star_max": 97.0,
      "chroma_scale_step": 0.9,
      "max_iterations": 32,
      "validation_delta_e00_tolerance": 0.5,
      "status": "icc_stub_pending_vendor_profile"
    }
  },
  "adaptive_palette": {
